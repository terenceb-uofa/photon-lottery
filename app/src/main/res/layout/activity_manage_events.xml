<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".admin.ManageEventsActivity">

    <TextView
        android:id="@+id/EventsTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#CD59A91E"
        android:gravity="center"
        android:padding="16dp"
        android:text="All Events"
        android:textColor="#FFFFFF"
        android:textSize="40sp"
        android:textStyle="bold"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="30dp"
        android:layout_marginHorizontal="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/EventsManagerBackButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⬅️Back"
        app:backgroundTint="#CD59A91E"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


    <ScrollView
        android:id="@+id/eventsScrollView"
        android:fillViewport="true"
        android:layout_height="0dp"
        android:layout_width="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/EventsTitle"
        app:layout_constraintBottom_toTopOf="@id/EventsManagerBackButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/eventsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp"/>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>