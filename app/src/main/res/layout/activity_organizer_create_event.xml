<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:paddingBottom="100dp">


        <FrameLayout
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/white" />
        </FrameLayout>

        <TextView
            android:id="@+id/screenTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Event"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/backButton" />



        <ImageView
            android:id="@+id/posterPreview"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:layout_marginTop="16dp"
            android:background="@color/navBackground"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/screenTitle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/uploadPosterButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:minHeight="48dp"
            android:text="Upload Poster"
            android:textColor="@color/white"
            app:backgroundTint="@color/ghostButton"
            app:cornerRadius="999dp"
            app:strokeColor="@color/ghostBorder"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/posterPreview" />



        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/nameInputLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Event Name"
            android:textColorHint="@color/textHint"
            app:boxBackgroundColor="@color/sepBackground"
            app:boxStrokeColor="@color/accent"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="@color/textHint"
            app:boxCornerRadiusTopStart="999dp"
            app:boxCornerRadiusTopEnd="999dp"
            app:boxCornerRadiusBottomStart="999dp"
            app:boxCornerRadiusBottomEnd="999dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/uploadPosterButton">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/nameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="textCapWords" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:id="@+id/eventDropdownRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/nameInputLayout">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/eventTypeInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:hint="Event Type"
                android:textColorHint="@color/textHint"
                app:boxBackgroundColor="@color/sepBackground"
                app:boxStrokeColor="@color/accent"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/textHint"
                app:endIconMode="dropdown_menu"
                app:endIconTint="@color/textHint"
                app:boxCornerRadiusTopStart="999dp"
                app:boxCornerRadiusTopEnd="999dp"
                app:boxCornerRadiusBottomStart="999dp"
                app:boxCornerRadiusBottomEnd="999dp">

                <AutoCompleteTextView
                    android:id="@+id/eventTypeInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="none"
                    android:focusable="false"
                    android:cursorVisible="false"
                    android:saveEnabled="false"
                    android:entries="@array/event_types" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/eventVisibilityInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="Visibility"
                android:textColorHint="@color/textHint"
                app:boxBackgroundColor="@color/sepBackground"
                app:boxStrokeColor="@color/accent"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/textHint"
                app:endIconMode="dropdown_menu"
                app:endIconTint="@color/textHint"
                app:boxCornerRadiusTopStart="999dp"
                app:boxCornerRadiusTopEnd="999dp"
                app:boxCornerRadiusBottomStart="999dp"
                app:boxCornerRadiusBottomEnd="999dp">

                <AutoCompleteTextView
                    android:id="@+id/eventVisibilityInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="none"
                    android:focusable="false"
                    android:cursorVisible="false"
                    android:saveEnabled="false"
                    android:entries="@array/visibility_types" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/descriptionInputLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Description"
            android:textColorHint="@color/textHint"
            app:boxBackgroundColor="@color/sepBackground"
            app:boxStrokeColor="@color/accent"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="@color/textHint"
            app:boxCornerRadiusTopStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusBottomEnd="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/eventDropdownRow">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/descriptionInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:inputType="textMultiLine|textCapSentences"
                android:textColor="@color/white"
                android:minLines="4"
                android:maxLines="6"
                android:scrollbars="vertical" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/addressInputLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Address"
            android:textColorHint="@color/textHint"
            app:boxBackgroundColor="@color/sepBackground"
            app:boxStrokeColor="@color/accent"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="@color/textHint"
            app:boxCornerRadiusTopStart="999dp"
            app:boxCornerRadiusTopEnd="999dp"
            app:boxCornerRadiusBottomStart="999dp"
            app:boxCornerRadiusBottomEnd="999dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/descriptionInputLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/addressInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPostalAddress"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:id="@+id/eventDateRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/addressInputLayout">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/startDateInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:hint="Start Date"
                android:textColorHint="@color/textHint"
                app:boxBackgroundColor="@color/sepBackground"
                app:boxStrokeColor="@color/accent"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/textHint"
                app:boxCornerRadiusTopStart="999dp"
                app:boxCornerRadiusTopEnd="999dp"
                app:boxCornerRadiusBottomStart="999dp"
                app:boxCornerRadiusBottomEnd="999dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/startDateInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/endDateInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="End Date"
                android:textColorHint="@color/textHint"
                app:boxBackgroundColor="@color/sepBackground"
                app:boxStrokeColor="@color/accent"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/textHint"
                app:boxCornerRadiusTopStart="999dp"
                app:boxCornerRadiusTopEnd="999dp"
                app:boxCornerRadiusBottomStart="999dp"
                app:boxCornerRadiusBottomEnd="999dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/endDateInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/drawDateInputLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Draw Date"
            android:textColorHint="@color/textHint"
            app:boxBackgroundColor="@color/sepBackground"
            app:boxStrokeColor="@color/accent"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="@color/textHint"
            app:boxCornerRadiusTopStart="999dp"
            app:boxCornerRadiusTopEnd="999dp"
            app:boxCornerRadiusBottomStart="999dp"
            app:boxCornerRadiusBottomEnd="999dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/eventDateRow">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/drawDateInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:id="@+id/registrationDateRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/drawDateInputLayout">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/registrationStartInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:hint="Reg. Start"
                android:textColorHint="@color/textHint"
                app:boxBackgroundColor="@color/sepBackground"
                app:boxStrokeColor="@color/accent"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/textHint"
                app:boxCornerRadiusTopStart="999dp"
                app:boxCornerRadiusTopEnd="999dp"
                app:boxCornerRadiusBottomStart="999dp"
                app:boxCornerRadiusBottomEnd="999dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/registrationStartInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/registrationEndInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="Reg. End"
                android:textColorHint="@color/textHint"
                app:boxBackgroundColor="@color/sepBackground"
                app:boxStrokeColor="@color/accent"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/textHint"
                app:boxCornerRadiusTopStart="999dp"
                app:boxCornerRadiusTopEnd="999dp"
                app:boxCornerRadiusBottomStart="999dp"
                app:boxCornerRadiusBottomEnd="999dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/registrationEndInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:inputType="none"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/capacityRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/registrationDateRow">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/capacityInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:hint="Capacity"
                android:textColorHint="@color/textHint"
                app:boxBackgroundColor="@color/sepBackground"
                app:boxStrokeColor="@color/accent"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/textHint"
                app:boxCornerRadiusTopStart="999dp"
                app:boxCornerRadiusTopEnd="999dp"
                app:boxCornerRadiusBottomStart="999dp"
                app:boxCornerRadiusBottomEnd="999dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/capacityInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/waitlistLimitInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="Waitlist Limit (Optional)"
                android:textColorHint="@color/textHint"
                app:boxBackgroundColor="@color/sepBackground"
                app:boxStrokeColor="@color/accent"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="@color/textHint"
                app:boxCornerRadiusTopStart="999dp"
                app:boxCornerRadiusTopEnd="999dp"
                app:boxCornerRadiusBottomStart="999dp"
                app:boxCornerRadiusBottomEnd="999dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/waitlistLimitInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/feeInputLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Signup Fee"
            android:textColorHint="@color/textHint"
            app:boxBackgroundColor="@color/sepBackground"
            app:boxStrokeColor="@color/accent"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="@color/textHint"
            app:boxCornerRadiusTopStart="999dp"
            app:boxCornerRadiusTopEnd="999dp"
            app:boxCornerRadiusBottomStart="999dp"
            app:boxCornerRadiusBottomEnd="999dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/capacityRow">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/feeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchRequireGeolocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Require Geolocation to Join Waitlist"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:thumbTint="@color/accent"
            app:trackTint="@color/sepBackground"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/feeInputLayout" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/createEventButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:minHeight="48dp"
            android:text="Create Event"
            android:textColor="@color/white"
            app:backgroundTint="@color/accent"
            app:cornerRadius="999dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/switchRequireGeolocation" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>