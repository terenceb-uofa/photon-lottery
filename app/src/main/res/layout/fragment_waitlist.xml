<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="12dp">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWaitlist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewMap"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:minHeight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="View Entrant Map"
        android:textColor="@color/white"
        app:backgroundTint="@color/ghostButton"
        app:strokeColor="@color/ghostBorder"
        app:strokeWidth="1dp"
        app:cornerRadius="999dp" />

    <LinearLayout
        android:id="@+id/publicButtonRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:visibility="gone"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNotifyWaitlist"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Notify"
            android:textColor="@color/white"
            app:backgroundTint="@color/ghostButton"
            app:strokeColor="@color/ghostBorder"
            app:strokeWidth="1dp"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDrawLottery"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Draw Lottery"
            android:textColor="@color/white"
            app:backgroundTint="@color/accent"
            app:cornerRadius="24dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/privateTopButtonRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:visibility="gone"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNotifyWaitlistPrivate"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Notify"
            android:textColor="@color/white"
            app:backgroundTint="@color/ghostButton"
            app:strokeColor="@color/ghostBorder"
            app:strokeWidth="1dp"
            app:cornerRadius="999dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInviteToWaitlist"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:minHeight="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Invite"
            android:textColor="@color/white"
            app:backgroundTint="@color/ghostButton"
            app:strokeColor="@color/ghostBorder"
            app:strokeWidth="1dp"
            app:cornerRadius="999dp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDrawLotteryPrivate"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:minHeight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:visibility="gone"
        android:text="Draw Lottery"
        android:textColor="@color/white"
        app:backgroundTint="@color/accent"
        app:cornerRadius="999dp" />

</LinearLayout>