<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <TextView
        android:id="@+id/HistoryTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Event History"
        android:textColor="#59A91E"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/emptyHistoryText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You haven't joined any events yet."
        android:textColor="#888888"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/HistoryTitle"
        app:layout_constraintBottom_toTopOf="@id/HistoryBackButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ListView
        android:id="@+id/historyListView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:divider="#333333"
        android:dividerHeight="1dp"
        app:layout_constraintTop_toBottomOf="@id/HistoryTitle"
        app:layout_constraintBottom_toTopOf="@id/HistoryBackButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_history_row" />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/HistoryBackButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⬅️ Back to Dashboard"
        android:textColor="#FFFFFF"
        app:backgroundTint="#333333"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>