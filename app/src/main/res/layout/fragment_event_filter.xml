<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_nav_glass">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Filter Events"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>


    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/filterEventTypeLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Event Type"
        android:textColorHint="@color/textHint"
        app:boxBackgroundColor="@color/sepBackground"
        app:boxStrokeColor="@color/accent"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="2dp"
        app:hintTextColor="@color/textHint"
        app:boxCornerRadiusTopStart="999dp"
        app:boxCornerRadiusTopEnd="999dp"
        app:boxCornerRadiusBottomStart="999dp"
        app:boxCornerRadiusBottomEnd="999dp">

        <AutoCompleteTextView
            android:id="@+id/filterEventTypeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:inputType="none"
            android:focusable="false"
            android:cursorVisible="false"
            android:saveEnabled="false"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/filterMinCapacityLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Minimum Capacity"
        android:textColorHint="@color/textHint"
        app:boxBackgroundColor="@color/sepBackground"
        app:boxStrokeColor="@color/accent"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="2dp"
        app:hintTextColor="@color/textHint"
        app:boxCornerRadiusTopStart="999dp"
        app:boxCornerRadiusTopEnd="999dp"
        app:boxCornerRadiusBottomStart="999dp"
        app:boxCornerRadiusBottomEnd="999dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/filterMinCapacityInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:inputType="number"/>
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp"
        android:weightSum="2">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/filterMinStartDateLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:hint="Start Date From"
            android:textColorHint="@color/textHint"
            app:boxBackgroundColor="@color/sepBackground"
            app:boxStrokeColor="@color/accent"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="@color/textHint"
            app:boxCornerRadiusTopStart="999dp"
            app:boxCornerRadiusTopEnd="999dp"
            app:boxCornerRadiusBottomStart="999dp"
            app:boxCornerRadiusBottomEnd="999dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/filterMinStartDateInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:focusable="false"
                android:inputType="none"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/filterMaxStartDateLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:hint="Start Date To"
            android:textColorHint="@color/textHint"
            app:boxBackgroundColor="@color/sepBackground"
            app:boxStrokeColor="@color/accent"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="2dp"
            app:hintTextColor="@color/textHint"
            app:boxCornerRadiusTopStart="999dp"
            app:boxCornerRadiusTopEnd="999dp"
            app:boxCornerRadiusBottomStart="999dp"
            app:boxCornerRadiusBottomEnd="999dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/filterMaxStartDateInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:focusable="false"
                android:inputType="none"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/filterClearButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="48dp"
            android:text="Clear"
            android:textColor="@color/white"
            app:backgroundTint="@color/navBackground"
            app:cornerRadius="999dp"
            app:strokeColor="@color/ghostBorder"
            app:strokeWidth="1dp"
            android:layout_marginEnd="8dp"
            />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/filterApplyButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="48dp"
            android:text="Apply"
            android:textColor="@color/white"
            app:backgroundTint="@color/accent"
            app:cornerRadius="999dp" />
    </LinearLayout>

</LinearLayout>