<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1E1E1E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filter Events"
        android:textColor="#59A91E"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/filterEventTypeLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Event Type"
        android:textColorHint="#B0B0B0"
        app:boxBackgroundColor="#1E1E1E"
        app:boxStrokeColor="#59A91E"
        app:hintTextColor="#59A91E">

        <AutoCompleteTextView
            android:id="@+id/filterEventTypeInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:inputType="none"
            android:focusable="false"
            android:cursorVisible="false"
            android:saveEnabled="false"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/filterMinCapacityLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Minimum Capacity"
        android:textColorHint="#B0B0B0"
        app:boxBackgroundColor="#1E1E1E"
        app:boxStrokeColor="#59A91E"
        app:hintTextColor="#59A91E">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/filterMinCapacityInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:inputType="number"/>
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp"
        android:weightSum="2">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/filterMinStartDateLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:hint="Start Date From"
            android:textColorHint="#B0B0B0"
            app:boxBackgroundColor="#1E1E1E"
            app:boxStrokeColor="#59A91E"
            app:hintTextColor="#59A91E">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/filterMinStartDateInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:focusable="false"
                android:inputType="none"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/filterMaxStartDateLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:hint="Start Date To"
            android:textColorHint="#B0B0B0"
            app:boxBackgroundColor="#1E1E1E"
            app:boxStrokeColor="#59A91E"
            app:hintTextColor="#59A91E">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/filterMaxStartDateInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:focusable="false"
                android:inputType="none"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/filterClearButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Clear"
            android:textColor="#FFFFFF"
            app:backgroundTint="#333333"
            app:cornerRadius="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/filterApplyButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Apply"
            android:textColor="#FFFFFF"
            app:backgroundTint="#59A91E"
            app:cornerRadius="8dp"/>
    </LinearLayout>

</LinearLayout>